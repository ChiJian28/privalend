package z:fraud-consortium@0.1.0;

world fraud-consortium {
  import host:tenant/tenant-context@1.0.0;
  import host:interfaces/logging@2.1.0;
  import host:interfaces/kv-store@2.1.0;

  export contracts;
}

interface contracts {
  record generic-input {
    input:        option<list<u8>>,
    user-profile: option<list<u8>>,
    context:      option<list<u8>>,
  }

  /// Check if a user DID appears on the industry fraud blacklist.
  /// Returns only a risk signal — never exposes blacklist contents.
  check-blacklist: func(req: generic-input) -> result<list<u8>, string>;
}
